setcps (167/60/4)

hush
-- junglu!

do
resetCycles
d1
    $ sh 0
    $ stack [
        -- qtrigger 1 .
        while "<0 0 0 [0 1 1]>" (jux (sh "<0.125!15 0>")) .
        struct "1*<8!31 [<8 4> <32 64 128>]>".
        slice 8 (run "{8 4 8 <10 11 10 12>}%2")
        $ s "<rvbreaks1!24 rvbreaks4!24>"
        -- $ s "<rvbreaks4!16>"
        # n "<0!7 10 5!7 [5 <2 3 4>]>"
        |+ n "<0!32 14!8 18!8>"
        -- |+ n "<18>"
        # legato 1
        # shape 0.7
        -- # krush 10
        # lpf 10000
        # lpq 0.1
        # phaserdepth 0.9
        # phaserrate 0.2
        # gain 2
        |* gain "<1!15 [1]>"
        # unit "c"
        ,
        struct "{1(3,8)}%1"
        $ s "909bd"
        # shape 0.99
        |* gain "<1!15 0>"
        # note "<-5!8 -3!8>"
        # legato 2
        # slide "-2"
        |* gain 1.6
    ]
    # comp 1
    # compPre 1
    # compMakeup 0.4
    # compThreshold 1
    # compRatio 30
    # compUp 40
    # compRelease 0.1
d2
    -- $ qtrigger 2
    $ while "<0 0 1 0 0 0 1 1>" ((|* speed (1/8)))
    $ stack [
        slow "<<2!2 1> [1 2]>" .
        struct "1*[16 8 16 16]"
        $ n (run 16 * "<2!2 3!2>")
        |% n "<[2 16]!16 3!16>"
        |+ n "<80 100> 81"
        # s "legperc legdx200"
        # legato 1
        # speed ("<4!8 10!8>")
        # krush 10
        |* gain 1.4
        |* gain "{1 0 1 1 1 1 0 0}%4"
        |* gain "<1!24 [1 0 1 0]!16>"
    ]
    # comp 1
    # compPre 100
    # compMakeup 0.2
    # compThreshold 0.8
    # compRatio 3
    # compUp 9
    # compRelease 0.05
    # verb 0.6 "<0.01!3 0.9>" 0.7 0.8 0.3
d3
    -- $ qtrigger 3
    $ slow 1
    $ stack [
        struct "{1@2 ~ 1@3 ~ ~}%8"
        $ s "909bd"
        # shape "<0.4 0.99>"
        -- # krush 2
        -- # silence
        -- # tilt 
        # speed "<1 -1>" 
        |* gain "<1 1 1 0>"
        |* gain 1.1
        # up "-3"
        ,
        struct "1*<16 [16 32] [32 64]*2>"
        $ s "808hh"
        # up "3"
        # legato 1
        # tilt 0.2
        # bpf 12000
        # hpf 10000
        # bpq 5
        # shape 0.9
    ]
    # compPre "20"
    # comp 1
    # compUp 10000
    # compThreshold 4
    # compRatio 4
    # compMakeup 0.2
    # compRelease 0.6
    # verb 0.3 0.9 0.8 0.9 0.33
    # legato 1
    -- # release 0.7
    # lpf 200
    |* gain 1
    






